    </div>
  </article>
</Layout>

<style>
  :root {
    --color-bg: #F8FAFC;
    --color-text: #0F172A;
    --color-primary: #F59E0B;
    --color-primary-dark: #D97706;
    --color-card-bg: #FFFFFF;
    --color-text-light: #64748B;
    --color-border: #E2E8F0;
  }

  .blog-post {
    background-color: var(--color-bg);
    color: var(--color-text);
    padding: 2rem 0 4rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .breadcrumb {
    margin-bottom: 2rem;
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  .breadcrumb ol {
    list-style: none;
    padding: 0;
