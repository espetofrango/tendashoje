    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-light);
    font-size: 0.95rem;
  }

  .featured-image {
    margin: 0 0 2.5rem 0;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .featured-image img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/9;
    object-fit: cover;
